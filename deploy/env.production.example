# Production .env on server (copy to /opt/even-app/.env, never commit).
# Replace CHANGE_ME values before first deploy.

# --- Postgres ---
POSTGRES_USER=even
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password
POSTGRES_PORT=5432

# --- MinIO / S3 (internal docker network) ---
S3_ENDPOINT=http://minio:9000
# Public URL for presigned media links (via SSH tunnel, nginx proxy, or opened port 9000)
S3_PUBLIC_ENDPOINT=http://91.218.245.136:9000
S3_BUCKET=even-media
S3_ACCESS_KEY=CHANGE_ME_minio_user
S3_SECRET_KEY=CHANGE_ME_minio_password

# --- Auth ---
JWT_SECRET=CHANGE_ME_long_random_jwt_secret

# --- Media ---
MEDIA_USER_QUOTA_BYTES=524288000

LOG_LEVEL=info
